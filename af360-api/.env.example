# Copie este arquivo para ".env" (uso local) e/ou cadastre as mesmas
# variáveis em Vercel → Project Settings → Environment Variables.
# NUNCA cometa o arquivo ".env" de verdade no Git.

# --- Conexão com o Postgres (banco AF360) ---
PGHOST=2.24.77.227
PGPORT=5432
PGDATABASE=AF360
PGUSER=lovable_ro
PGPASSWORD=Af@#360
PGSSL=false

# Máximo de conexões simultâneas que ESTA instância da API pode abrir
# no Postgres. Mantenha baixo (1-3) em ambiente serverless, porque cada
# execução "fria" pode criar seu próprio pool.
PGPOOL_MAX=2

# --- Segurança da própria API ---
# Chave que o app deve enviar no header "x-api-key" em toda chamada.
# Gere algo aleatório (ex.: openssl rand -hex 24) e cadastre o mesmo
# valor no app (variável de ambiente do Expo/EAS, nunca hardcoded no
# repositório público).
API_KEY=troque-por-uma-chave-aleatoria-longa
